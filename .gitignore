# ── Personal config (contains private athlete data) ──────────────────────────
runtrackz.yml
.runtrackz.yml

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env

# ── Data files (fit files may contain personal GPS data) ─────────────────────
*.fit
*.FIT

# ── Database (contains personal training data) ───────────────────────────────
*.db
*.duckdb

# ── Data folder contents (raw .fit files, processed parquet, DuckDB) ──────────
# Keep the folder structure (.gitkeep files are tracked); ignore the data itself
data/raw/*
data/processed/*
data/database/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/database/.gitkeep

# ── Generated outputs ─────────────────────────────────────────────────────────
*.png
*.pdf
*.csv
*.parquet

# ── IDEs & editors ────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
